<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{{ title }}</title>
<style>
  :root {
    --bg: #0e1116;
    --panel: #161b22;
    --border: #30363d;
    --text: #e6edf3;
    --muted: #8b949e;
    --accent: #3b82f6;
  }
  * { box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    height: 100vh;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }
  header {
    padding: 16px 28px;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(180deg, #1b2230, var(--panel));
    display: flex;
    align-items: baseline;
    gap: 16px;
  }
  header h1 { margin: 0; font-size: 22px; }
  header .sub { color: var(--muted); font-size: 14px; }
  .layout { display: flex; flex: 1; min-height: 0; }
  .sidebar {
    width: 300px;
    border-right: 1px solid var(--border);
    background: var(--panel);
    padding: 12px 0;
    overflow-y: auto;
  }
  .sidebar h2 {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding: 0 16px;
    margin: 8px 0;
  }
  .chapter {
    display: block;
    width: 100%;
    text-align: left;
    background: none;
    border: none;
    color: var(--text);
    padding: 10px 16px;
    cursor: pointer;
    font-size: 14px;
  }
  .chapter:hover { background: rgba(59,130,246,0.12); }
  .chapter.active {
    background: rgba(59,130,246,0.20);
    border-left: 3px solid var(--accent);
  }
  .stage {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 24px;
    gap: 20px;
  }
  .frame {
    max-width: 100%;
    max-height: 64vh;
    border: 1px solid var(--border);
    border-radius: 10px;
    box-shadow: 0 12px 40px rgba(0,0,0,0.45);
    background: #0a0d12;
  }
  .caption {
    font-size: 24px;
    line-height: 1.5;
    text-align: center;
    max-width: 880px;
    min-height: 2em;
    color: #f3f6fa;
  }
  .controls {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .controls button {
    background: var(--accent);
    color: white;
    border: none;
    border-radius: 6px;
    padding: 8px 16px;
    font-size: 14px;
    cursor: pointer;
  }
  .controls button:hover { filter: brightness(1.1); }
  .clock { color: var(--muted); font-variant-numeric: tabular-nums; }
</style>
</head>
<body>
<header><h1>{{ title }}</h1><span class="sub">DemoCreate interactive player · {{ chapters|length }} chapters</span></header>
<div class="layout">
  <nav class="sidebar">
    <h2>Chapters</h2>
    {% for ch in chapters %}
    <button class="chapter" data-start="{{ ch.start_ms }}" data-scene="{{ ch.scene_id }}">{{ ch.title }}</button>
    {% endfor %}
  </nav>
  <main class="stage">
    {% if frames_dir %}
    <img id="frame" class="frame" alt="current frame" />
    {% endif %}
    <div id="caption" class="caption"></div>
    <div class="controls">
      <button id="prev">&#9664; Prev</button>
      <button id="play">Play</button>
      <button id="next">Next &#9654;</button>
      <span id="clock" class="clock">0.0s</span>
    </div>
  </main>
</div>
<script>
const CAPTIONS = {{ captions_json }};
const CHAPTERS = {{ chapters_json }};
const FRAMES_DIR = {{ frames_dir_json }};
const TOTAL_MS = {{ total_ms }};

let timeMs = 0;
let playing = false;
let timer = null;
const STEP_MS = 100;

const captionEl = document.getElementById("caption");
const clockEl = document.getElementById("clock");
const playBtn = document.getElementById("play");
const frameEl = document.getElementById("frame");
const chapterBtns = Array.from(document.querySelectorAll(".chapter"));

function currentCueIndex(t) {
  let idx = 0;
  for (let i = 0; i < CAPTIONS.length; i++) {
    if (CAPTIONS[i].start_ms <= t) idx = i;
  }
  return CAPTIONS.length ? idx : -1;
}

function render() {
  const idx = currentCueIndex(timeMs);
  if (idx >= 0) {
    const cue = CAPTIONS[idx];
    captionEl.textContent = cue.text;
    if (frameEl && FRAMES_DIR && cue.frame) {
      frameEl.src = FRAMES_DIR + "/" + cue.frame;
    }
    chapterBtns.forEach((b) => b.classList.remove("active"));
    const active = chapterBtns.filter((b) => Number(b.dataset.start) <= timeMs).pop();
    if (active) active.classList.add("active");
  }
  clockEl.textContent = (timeMs / 1000).toFixed(1) + "s";
}

function seek(ms) {
  timeMs = Math.max(0, Math.min(ms, TOTAL_MS));
  render();
}

function step(dir) {
  const idx = currentCueIndex(timeMs);
  const next = Math.max(0, Math.min(idx + dir, CAPTIONS.length - 1));
  if (CAPTIONS[next]) seek(CAPTIONS[next].start_ms);
}

function tick() {
  timeMs += STEP_MS;
  if (timeMs >= TOTAL_MS) {
    timeMs = TOTAL_MS;
    pause();
  }
  render();
}

function play() {
  if (playing) return;
  playing = true;
  playBtn.textContent = "Pause";
  timer = setInterval(tick, STEP_MS);
}

function pause() {
  playing = false;
  playBtn.textContent = "Play";
  if (timer) clearInterval(timer);
  timer = null;
}

playBtn.addEventListener("click", () => (playing ? pause() : play()));
document.getElementById("prev").addEventListener("click", () => step(-1));
document.getElementById("next").addEventListener("click", () => step(1));
chapterBtns.forEach((b) =>
  b.addEventListener("click", () => seek(Number(b.dataset.start)))
);

render();
</script>
</body>
</html>
